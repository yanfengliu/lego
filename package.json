{
  "name": "lego-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @lego-studio/web",
    "build": "npm run typecheck && npm run build --workspace @lego-studio/web && node scripts/check-production-bundle.mjs",
    "bom:check": "node scripts/check-bom.mjs",
    "notices:generate": "node scripts/generate-third-party-notices.mjs",
    "notices:check": "node scripts/generate-third-party-notices.mjs --check",
    "schema:generate": "npm run schema:generate --workspace @lego-studio/protocol",
    "schema:check": "npm run schema:check --workspace @lego-studio/protocol",
    "node:check": "node scripts/check-node-consumers.mjs",
    "test": "vitest run",
    "test:browser": "playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run schema:check && npm run node:check && npm run bom:check && npm run notices:check && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run test:browser && npm run build",
    "audit:runtime": "npm audit --omit=dev --audit-level=high",
    "audit": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "json-schema-to-typescript": "15.0.4",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
